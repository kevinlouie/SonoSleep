# Copy to .env and fill in. .env is gitignored — never commit real tokens.

# HTTP stream + health server
HWN_HTTP_ADDR=:8099
# URL the Sonos fetches — MUST be LAN-reachable (Synology host IP/hostname, not localhost)
HWN_PUBLIC_BASE_URL=http://192.168.1.50:8099

# Home Assistant REST API
HWN_HA_BASE_URL=http://homeassistant.local:8123
HWN_HA_TOKEN=replace-with-long-lived-access-token
HWN_HA_MEDIA_PLAYER=media_player.bedroom

# MQTT broker (Home Assistant's broker)
HWN_MQTT_BROKER=tcp://192.168.1.50:1883
HWN_MQTT_USER=
HWN_MQTT_PASS=

# Defaults
HWN_DEFAULT_PRESET=brown
HWN_DEFAULT_VOLUME=80

# Logging: debug | info | warn | error (default info). Structured (log/slog) to stderr.
HWN_LOG_LEVEL=info
